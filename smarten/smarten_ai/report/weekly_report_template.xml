<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="weekly_attendance_report">
        <t t-call="web.html_container">
            <div class="page">
                <h2>Weekly Attendance Summary</h2>
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>IN Time</th>
                            <th>OUT Time</th>
                            <th>Duration (h)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="doc">
                            <tr>
                                <td><t t-esc="doc.person_id.name"/></td>
                                <td><t t-esc="doc.entry_time"/></td>
                                <td><t t-esc="doc.exit_time"/></td>
                                <td><t t-esc="doc.duration"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
</odoo>
