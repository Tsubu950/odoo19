<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_smarten" model="ir.module.category">
            <field name="name">Smarten AI</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_smarten_user" model="res.groups">
            <field name="name">Smarten User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_smarten_manager" model="res.groups">
            <field name="name">Smarten Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_smarten_user'))]"/>
        </record>
    </data>
</odoo>