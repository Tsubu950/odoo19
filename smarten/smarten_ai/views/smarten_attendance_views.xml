<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_smarten_attendance_log_list" model="ir.ui.view">
        <field name="name">smarten.attendance.log.list</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="entry_time"/>
                <field name="exit_time"/>
                <field name="person_id"/>
                <field name="direction" widget="badge"/>
                <field name="camera_source"/>
                <field name="duration" widget="float_time"/>
                <field name="gender"/>                 <!-- new -->
                <field name="age_range"/>              <!-- new -->
                <field name="liveness_score" widget="progressbar"/>
                <field name="person_type"/>
                <field name="photo" />   <!-- new -->
            </list>
        </field>
    </record>

    <!-- Kanban View (Odoo 19 "card" template) -->
    <record id="view_smarten_attendance_log_kanban" model="ir.ui.view">
        <field name="name">smarten.attendance.log.kanban</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="person_id"/>
                <field name="direction"/>
                <field name="person_type"/>
                <field name="entry_time"/>
                <field name="photo"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <t t-if="record.photo.raw_value">
                                <img t-attf-src="data:image/jpeg;base64,#{record.photo.raw_value}" alt="Snapshot" style="width:100%; height: auto;"/>
                            </t>
                            <div class="oe_kanban_content">
                                <strong><t t-esc="record.person_id.raw_value"/></strong>
                                <br/>
                                <t t-esc="record.direction.raw_value"/> – <t t-esc="record.person_type.raw_value"/>
                                <br/>
                                <small><t t-esc="record.entry_time.raw_value"/></small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View (new) -->
    <record id="view_smarten_attendance_log_form" model="ir.ui.view">
        <field name="name">smarten.attendance.log.form</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1><field name="person_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="entry_time"/>
                            <field name="exit_time"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group>
                            <field name="direction"/>
                            <field name="camera_source"/>
                            <field name="person_type"/>
                        </group>
                        <group>
                            <field name="gender"/>
                            <field name="age_range"/>
                            <field name="liveness_score" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <field name="photo" widget="image" class="oe_avatar"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_smarten_attendance_log_pivot" model="ir.ui.view">
        <field name="name">smarten.attendance.log.pivot</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="person_type" type="row"/>
                <field name="entry_time" interval="month" type="col"/>
                <field name="duration" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_smarten_attendance_log_graph" model="ir.ui.view">
        <field name="name">smarten.attendance.log.graph</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <graph>
                <field name="entry_time" interval="day"/>
                <field name="person_type"/>
                <field name="duration"/>
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_smarten_attendance_log_calendar" model="ir.ui.view">
        <field name="name">smarten.attendance.log.calendar</field>
        <field name="model">smarten.attendance.log</field>
        <field name="arch" type="xml">
            <calendar date_start="entry_time" date_stop="exit_time" color="person_type">
                <field name="person_id"/>
            </calendar>
        </field>
    </record>

    <!-- Main Action (added "form" to view_mode) -->
    <record id="action_smarten_attendance_log" model="ir.actions.act_window">
        <field name="name">All Attendance Logs</field>
        <field name="res_model">smarten.attendance.log</field>
        <field name="view_mode">list,kanban,form,pivot,graph,calendar</field>
    </record>

</odoo>