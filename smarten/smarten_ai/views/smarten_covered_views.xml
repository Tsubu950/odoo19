<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smarten_covered_log_list" model="ir.ui.view">
        <field name="name">smarten.covered.log.list</field>
        <field name="model">smarten.covered.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="tracking_id"/>
                <field name="direction" widget="badge"/>
                <field name="camera_source"/>
                <field name="entry_time"/>
                <field name="exit_time"/>
                <field name="duration" widget="float_time"/>
                <field name="photo"/>   <!-- NO widget="image" in list -->
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_smarten_covered_log_kanban" model="ir.ui.view">
        <field name="name">smarten.covered.log.kanban</field>
        <field name="model">smarten.covered.log</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="tracking_id"/>
                <field name="entry_time"/>
                <field name="photo"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <t t-if="record.photo.raw_value">
                                <img t-attf-src="data:image/jpeg;base64,#{record.photo.raw_value}" alt="Snapshot" style="width:100%; height: auto;"/>
                            </t>
                            <div class="oe_kanban_content">
                                <strong>Covered <t t-esc="record.tracking_id.raw_value"/></strong>
                                <br/>
                                <small><t t-esc="record.entry_time.raw_value"/></small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_smarten_covered_log_form" model="ir.ui.view">
        <field name="name">smarten.covered.log.form</field>
        <field name="model">smarten.covered.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="tracking_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="entry_time"/>
                            <field name="exit_time"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group>
                            <field name="direction"/>
                            <field name="camera_source"/>
                        </group>
                    </group>
                    <group>
                        <field name="photo" widget="image" class="oe_avatar"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smarten_covered_log" model="ir.actions.act_window">
        <field name="name">Covered Faces</field>
        <field name="res_model">smarten.covered.log</field>
        <field name="view_mode">list,kanban</field>
    </record>
</odoo>