<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="view_smarten_raw_log_list" model="ir.ui.view">
        <field name="name">smarten.raw.log.list</field>
        <field name="model">smarten.raw.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="track_id"/>
                <field name="camera_id"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Kanban view (dashboard) -->
    <record id="view_smarten_raw_log_kanban" model="ir.ui.view">
        <field name="name">smarten.raw.log.kanban</field>
        <field name="model">smarten.raw.log</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" create="false">
                <field name="id"/>
                <field name="track_id"/>
                <field name="camera_id"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="create_date"/>
                <field name="snapshot"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <t t-if="record.snapshot.raw_value">
                                <img t-attf-src="data:image/jpeg;base64,#{record.snapshot.raw_value}" alt="Snapshot" style="width:100%; height: auto;"/>
                            </t>
                            <div class="oe_kanban_content">
                                <strong>Track <t t-esc="record.track_id.raw_value"/></strong>
                                (<t t-esc="record.camera_id.raw_value"/>)
                                <br/>
                                <t t-esc="record.gender.raw_value"/>, age <t t-esc="record.age.raw_value"/>
                                <br/>
                                <small><t t-esc="record.create_date.raw_value"/></small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form view (detail) -->
    <record id="view_smarten_raw_log_form" model="ir.ui.view">
        <field name="name">smarten.raw.log.form</field>
        <field name="model">smarten.raw.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>Raw Detection <field name="track_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="camera_id"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="bbox"/>
                        </group>
                        <group>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <group string="Snapshot">
                        <field name="snapshot" widget="image" class="oe_avatar"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_smarten_raw_log" model="ir.actions.act_window">
        <field name="name">Live Raw Feed</field>
        <field name="res_model">smarten.raw.log</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="view_smarten_raw_log_kanban"/>
    </record>
</odoo>