<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smarten_reid_list" model="ir.ui.view">
        <field name="name">smarten.reid.embedding.list</field>
        <field name="model">smarten.reid.embedding</field>
        <field name="arch" type="xml">
            <list>
                <field name="person_name"/>
                <field name="employee_id"/>
                <field name="camera_source"/>
                <field name="first_seen"/>
                <field name="last_seen"/>
                <field name="track_id"/>
            </list>
        </field>
    </record>

    <record id="view_smarten_reid_form" model="ir.ui.view">
        <field name="name">smarten.reid.embedding.form</field>
        <field name="model">smarten.reid.embedding</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="person_name"/>
                        <field name="employee_id"/>
                        <field name="camera_source"/>
                        <field name="first_seen"/>
                        <field name="last_seen"/>
                        <field name="track_id"/>
                        <field name="embedding" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smarten_reid" model="ir.actions.act_window">
        <field name="name">ReID Embeddings</field>
        <field name="res_model">smarten.reid.embedding</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>