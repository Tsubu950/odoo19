<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_omni" model="ir.ui.view">
        <field name="name">hr.employee.form.omni</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="AI Monitoring">
                    <group>
                        <field name="is_vip"/>
                        <field name="is_blocked"/>
                        <field name="blocked_reason" invisible="not is_blocked"/>
                        <field name="face_image"/>
                        <field name="ai_face_encoding"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>