<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_analytics_list" model="ir.ui.view">
        <field name="name">gym.analytics.list</field>
        <field name="model">gym.analytics</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="male_count"/>
                <field name="female_count"/>
                <field name="total_visits"/>
                <field name="peak_hour"/>
            </list>
        </field>
    </record>

    <record id="view_gym_analytics_form" model="ir.ui.view">
        <field name="name">gym.analytics.form</field>
        <field name="model">gym.analytics</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="male_count"/>
                        <field name="female_count"/>
                        <field name="total_visits"/>
                        <field name="peak_hour"/>
                        <field name="age_distribution"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gym_analytics" model="ir.actions.act_window">
        <field name="name">Analytics</field>
        <field name="res_model">gym.analytics</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>