<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_guest_log_list" model="ir.ui.view">
        <field name="name">gym.guest.log.list</field>
        <field name="model">gym.guest.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="guest_id"/>
                <field name="gender"/>
                <field name="age_range"/>
                <field name="camera_source"/>
                <field name="is_resolved"/>
            </list>
        </field>
    </record>

    <record id="view_gym_guest_log_form" model="ir.ui.view">
        <field name="name">gym.guest.log.form</field>
        <field name="model">gym.guest.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="guest_id"/>
                            <field name="gender"/>
                            <field name="age_range"/>
                            <field name="camera_source"/>
                            <field name="timestamp"/>
                            <field name="is_resolved"/>
                        </group>
                        <group>
                            <field name="image" widget="image"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gym_guest_log" model="ir.actions.act_window">
        <field name="name">Guest Logs</field>
        <field name="res_model">gym.guest.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>