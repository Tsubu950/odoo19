<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_vip_alert" model="mail.template">
            <field name="name">VIP Entry Alert</field>
            <field name="model_id" ref="model_smarten_vip_log"/>
            <field name="email_from">${object.env.user.email_formatted}</field>
            <field name="subject">VIP Entry: ${object.employee_id.name}</field>
            <field name="body_html"><![CDATA[
                <p>VIP <strong>${object.employee_id.name}</strong> entered at ${object.entry_time}.</p>
            ]]></field>
        </record>

        <record id="mail_template_weekly_report" model="mail.template">
            <field name="name">Weekly Attendance Report</field>
            <field name="model_id" ref="model_smarten_attendance_log"/>
            <field name="subject">Weekly Attendance Report</field>
            <field name="body_html"><![CDATA[
                <p>Please find attached the weekly attendance summary.</p>
            ]]></field>
            <!-- report_template removed temporarily to avoid loading error -->
        </record>

        <record id="mail_template_monthly_report" model="mail.template">
            <field name="name">Monthly Attendance Report</field>
            <field name="model_id" ref="model_smarten_attendance_log"/>
            <field name="subject">Monthly Attendance Report</field>
            <field name="body_html"><![CDATA[
                <p>Please find attached the monthly attendance summary.</p>
            ]]></field>
        </record>
    </data>
</odoo>