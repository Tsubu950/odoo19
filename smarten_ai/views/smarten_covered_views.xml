<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smarten_covered_log_list" model="ir.ui.view">
        <field name="name">smarten.covered.log.list</field>
        <field name="model">smarten.covered.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="tracking_id"/>
                <field name="direction" widget="badge"/>
                <field name="camera_source"/>
                <field name="entry_time"/>
                <field name="exit_time"/>
                <field name="duration" widget="float_time"/>
                <field name="photo" widget="image"/>
            </list>
        </field>
    </record>

    <record id="view_smarten_covered_log_kanban" model="ir.ui.view">
        <field name="name">smarten.covered.log.kanban</field>
        <field name="model">smarten.covered.log</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('smarten.covered.log', 'photo', record.id.raw_value)" alt="Full body"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="tracking_id"/></strong>
                                <div><field name="direction"/></div>
                                <div><field name="entry_time"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_smarten_covered_log" model="ir.actions.act_window">
        <field name="name">Covered Faces</field>
        <field name="res_model">smarten.covered.log</field>
        <field name="view_mode">list,kanban</field>
    </record>
</odoo>