<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_smarten_visitor_tree" model="ir.ui.view">
        <field name="name">smarten.visitor.pre_registration.tree</field>
        <field name="model">smarten.visitor.pre_registration</field>
        <field name="arch" type="xml">
            <list>
                <field name="visitor_name"/>
                <field name="visit_date"/>
                <field name="host_id"/>
                <field name="status" widget="badge"/>
                <field name="token"/>
            </list>
        </field>
    </record>

    <record id="view_smarten_visitor_form" model="ir.ui.view">
        <field name="name">smarten.visitor.pre_registration.form</field>
        <field name="model">smarten.visitor.pre_registration</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="visitor_name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="visit_date"/>
                        <field name="host_id"/>
                        <field name="purpose"/>
                        <field name="status" widget="statusbar"/>
                        <field name="token" readonly="1"/>
                        <field name="check_in_time"/>
                        <field name="check_out_time"/>
                    </group>
                    <field name="face_image" widget="image" class="oe_avatar"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_smarten_visitor_kanban" model="ir.ui.view">
        <field name="name">smarten.visitor.pre_registration.kanban</field>
        <field name="model">smarten.visitor.pre_registration</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('smarten.visitor.pre_registration', 'face_image', record.id.raw_value)" alt="Photo"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="visitor_name"/></strong>
                                <div><field name="visit_date"/></div>
                                <div><field name="status" widget="badge"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_smarten_visitor_calendar" model="ir.ui.view">
        <field name="name">smarten.visitor.pre_registration.calendar</field>
        <field name="model">smarten.visitor.pre_registration</field>
        <field name="arch" type="xml">
            <calendar date_start="visit_date" color="status">
                <field name="visitor_name"/>
            </calendar>
        </field>
    </record>

    <record id="action_smarten_visitor" model="ir.actions.act_window">
        <field name="name">Visitor Pre‑registrations</field>
        <field name="res_model">smarten.visitor.pre_registration</field>
        <field name="view_mode">list,kanban,calendar,form</field>
    </record>
</odoo>