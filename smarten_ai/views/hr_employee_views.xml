<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_smarten" model="ir.ui.view">
        <field name="name">hr.employee.form.smarten</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Smarten AI">
                    <group>
                        <field name="is_vip"/>
                        <field name="is_blocked"/>
                        <field name="blocked_reason" invisible="not is_blocked"/>
                        <field name="face_image" widget="image"/>
                        <field name="ai_face_encoding" invisible="1"/>
                        <field name="firebase_token"/>
                        <field name="telegram_chat_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_hr_employee_smarten" model="ir.actions.act_window">
        <field name="name">Employees (Smarten AI)</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>
</odoo>