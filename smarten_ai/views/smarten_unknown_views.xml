<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_smarten_unknown_log_list" model="ir.ui.view">
        <field name="name">smarten.unknown.log.list</field>
        <field name="model">smarten.unknown.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="unknown_id"/>
                <field name="direction" widget="badge"/>
                <field name="camera_source"/>
                <field name="entry_time"/>
                <field name="exit_time"/>
                <field name="duration" widget="float_time"/>
                <field name="gender"/>
                <field name="age_range"/>
                <field name="liveness_score" widget="progressbar"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_smarten_unknown_log_kanban" model="ir.ui.view">
        <field name="name">smarten.unknown.log.kanban</field>
        <field name="model">smarten.unknown.log</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('smarten.unknown.log', 'photo', record.id.raw_value)" alt="Snapshot"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="unknown_id"/></strong>
                                <div><field name="direction"/></div>
                                <div><field name="entry_time"/></div>
                                <div>Gender: <field name="gender"/> | Age: <field name="age_range"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_smarten_unknown_log_pivot" model="ir.ui.view">
        <field name="name">smarten.unknown.log.pivot</field>
        <field name="model">smarten.unknown.log</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="gender" type="row"/>
                <field name="age_range" type="col"/>
                <field name="duration" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View (corrected: removed :day modifier) -->
    <record id="view_smarten_unknown_log_graph" model="ir.ui.view">
        <field name="name">smarten.unknown.log.graph</field>
        <field name="model">smarten.unknown.log</field>
        <field name="arch" type="xml">
            <graph>
                <field name="entry_time"/>
                <field name="gender"/>
                <field name="duration"/>
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_smarten_unknown_log_calendar" model="ir.ui.view">
        <field name="name">smarten.unknown.log.calendar</field>
        <field name="model">smarten.unknown.log</field>
        <field name="arch" type="xml">
            <calendar date_start="entry_time" date_stop="exit_time" color="gender">
                <field name="unknown_id"/>
            </calendar>
        </field>
    </record>

    <!-- Action -->
    <record id="action_smarten_unknown_log" model="ir.actions.act_window">
        <field name="name">Unknown Persons</field>
        <field name="res_model">smarten.unknown.log</field>
        <field name="view_mode">list,kanban,pivot,graph,calendar</field>
    </record>
</odoo>