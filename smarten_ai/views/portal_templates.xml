<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_visitor_registration" name="Visitor Pre‑registration" page="True">
        <t t-call="portal.portal_layout">
            <div class="container">
                <h1>Pre‑register Your Visit</h1>
                <form action="/api/smarten/visitor/register" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="name" class="form-control" required="1"/>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" class="form-control"/>
                    </div>
                    <div class="form-group">
                        <label>Visit Date</label>
                        <input type="date" name="visit_date" class="form-control" required="1"/>
                    </div>
                    <div class="form-group">
                        <label>Face Photo</label>
                        <input type="file" name="face_image" accept="image/*" required="1"/>
                    </div>
                    <button type="submit" class="btn btn-primary">Register</button>
                </form>
            </div>
        </t>
    </template>
</odoo>